# ============================================================
# EraseGraph — Environment Variables
# ============================================================
# Copy this file:   cp .env.example .env
# Then edit .env with your own values if needed.
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=erasegraph
POSTGRES_PASSWORD=erasegraph_secret
POSTGRES_DB=erasegraph
POSTGRES_PORT=5434
DATABASE_URL=postgresql://erasegraph:erasegraph_secret@localhost:5434/erasegraph

# ── Redis ───────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_USER=erasegraph
RABBITMQ_PASSWORD=erasegraph_secret
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_URL=amqp://erasegraph:erasegraph_secret@localhost:5672

# ── Jaeger / OpenTelemetry ──────────────────────────────────
JAEGER_UI_PORT=16686
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Backend API ─────────────────────────────────────────────
BACKEND_PORT=3001
NODE_ENV=development

# ── Development/Testing ─────────────────────────────────────
# JWT secret for authentication (if implementing later)
JWT_SECRET=your-super-secure-jwt-secret-key-here

# Log levels: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info
