{
  "id": null,
  "uid": "erasegraph-main",
  "title": "EraseGraph — Deletion Metrics",
  "description": "Live view of deletion requests, step statuses, proof events, and retries.",
  "tags": ["erasegraph"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Deletion Requests",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "erasegraph_deletion_requests_total{app=\"erasegraph-backend\"}",
          "legendFormat": "Total",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Completed Requests",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "erasegraph_deletion_requests_by_status{status=\"COMPLETED\",app=\"erasegraph-backend\"}",
          "legendFormat": "Completed",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Failed Requests",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "erasegraph_deletion_requests_by_status{status=\"FAILED\",app=\"erasegraph-backend\"}",
          "legendFormat": "Failed",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Current Retry Count",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "erasegraph_proof_retries_total{app=\"erasegraph-backend\"}",
          "legendFormat": "Retries",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Throughput Over Time",
      "description": "Rate of change in total deletion requests (requests/min)",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(erasegraph_deletion_requests_total{app=\"erasegraph-backend\"}[5m])",
          "legendFormat": "Requests/sec"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Deletion Requests by Status Over Time",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "erasegraph_deletion_requests_by_status{app=\"erasegraph-backend\"}",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Deletion Steps by Status Over Time",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "erasegraph_deletion_steps_by_status{app=\"erasegraph-backend\"}",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Proof Events Total",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "purple", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "erasegraph_proof_events_total{app=\"erasegraph-backend\"}",
          "legendFormat": "Proof Events"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Retries Over Time",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "erasegraph_proof_retries_total{app=\"erasegraph-backend\"}",
          "legendFormat": "Retries"
        }
      ]
    }
  ]
}
